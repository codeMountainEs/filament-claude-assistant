{
    "name": "codemountain/filament-claude-assistant",
    "description": "Filament plugin: AI chat assistant powered by Anthropic Claude with tool use. Drop-in for any Laravel + Filament app.",
    "type": "library",
    "keywords": ["laravel", "filament", "claude", "anthropic", "ai", "assistant", "tool-use", "livewire"],
    "license": "MIT",
    "authors": [
        {
            "name": "CodeMountain",
            "email": "codemountain.bernesga@gmail.com",
            "homepage": "https://codemountain.es"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0 || ^4.0",
        "illuminate/contracts": "^11.0 || ^12.0",
        "illuminate/http": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^2.0 || ^3.0",
        "pestphp/pest-plugin-laravel": "^2.0 || ^3.0"
    },
    "autoload": {
        "psr-4": {
            "CodeMountain\\FilamentClaudeAssistant\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodeMountain\\FilamentClaudeAssistant\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodeMountain\\FilamentClaudeAssistant\\ClaudeAssistantServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
